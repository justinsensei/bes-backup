+    def test_strips_empty_strings_from_enums(self):
+        """Empty strings inside enum lists must be stripped for Gemini."""
+        schema = {"type": "string", "enum": ["exact", "is_not", ""]}
+        cleaned = sanitize_gemini_schema(schema)
+        assert cleaned["enum"] == ["exact", "is_not"]
+
+    def test_strips_empty_string_only_enums_entirely(self):
+        """Enums with only empty strings must be removed entirely."""
+        schema = {"type": "string", "enum": [""]}
+        cleaned = sanitize_gemini_schema(schema)
+        assert "enum" not in cleaned
